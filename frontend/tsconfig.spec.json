{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": [
      "jest",
      "node"
    ],
    "paths": {
      "kubeflow": ["__mocks__/kubeflow.ts"],
      "kubeflow/*": ["__mocks__/kubeflow.ts"]
    }
  },
  "files": [
    "src/polyfills.ts",
    "src/test-setup.jest.ts"
  ],
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "__mocks__/**/*.ts"
  ]
}
